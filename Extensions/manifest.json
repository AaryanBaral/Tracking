{
  "name": "Employee Tracker Bridge",
  "version": "0.2.0",
  "manifest_version": 3,
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:43121/*",
    "https://*.youtube.com/*",
    "https://*.vimeo.com/*",
    "https://*.teams.microsoft.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.vimeo.com/*",
        "https://*.teams.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Tracker.Api.Middleware.RequestLoggingMiddleware": "Information",
      "Tracker.Api.Endpoints": "Information",
      "Tracker.Api.Services.IngestService": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {

  },
  "Auth": {
    "Issuer": "EmployeeTracker",
    "Audience": "EmployeeTrackerAdmin",
    "SigningKey": "change-this-key-to-a-32-byte-secret",
    "TokenMinutes": 720
  },
  "AdminSeed": {
    "Enabled": true,
    "Email": "admin@example.com",
    "Password": "Password@123",
    "Role": "SystemAdmin",
    "CompanyName": "System",
    "CompanyEnrollmentKey": "crown-institute"
  },
  "RateLimiting": {
    "IngestPermitLimit": 120,
    "IngestWindowSeconds": 60,
    "IngestQueueLimit": 0,
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 60,
    "AuthQueueLimit": 0
  }
}

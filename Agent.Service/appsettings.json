{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Agent.Service.Tracking.AppSessionizer": "Information",
      "Agent.Service.Workers.OutboxSenderWorker": "Information"
    }
  },
  "Agent": {
    "PollIntervalSeconds": 5,
    "LogIdleEvents": true,
    "LogAppEvents": true,
    "LogWebEvents": true,
    "EnableLocalCollectors": true,
    "IdleThresholdSeconds": 60,
    "IdleSessionCheckpointSeconds": 0,
    "CompanyEnrollmentKey": "crown-institute",
    "BrowserEventEndpoint": "http://localhost:5002/events",
    "WebEventIngestEndpoint": "http://localhost:5002/events/web/batch",
    "WebSessionIngestEndpoint": "http://localhost:5002/ingest/web-sessions",
    "AppSessionIngestEndpoint": "http://localhost:5002/ingest/app-sessions",
    "IdleSessionIngestEndpoint": "http://localhost:5002/ingest/idle-sessions",
    "DeviceSessionIngestEndpoint": "http://localhost:5002/ingest/device-sessions",
    "WebEventBatchSize": 50,
    "WebSessionBatchSize": 50,
    "AppSessionBatchSize": 50,
    "IdleSessionBatchSize": 50,
    "DeviceSessionBatchSize": 50,
    "WebEventSendMinSeconds": 10,
    "WebEventSendMaxSeconds": 30,
    "WebSessionSendMinSeconds": 10,
    "WebSessionSendMaxSeconds": 30,
    "AppSessionSendMinSeconds": 10,
    "AppSessionSendMaxSeconds": 30,
    "IdleSessionSendMinSeconds": 10,
    "IdleSessionSendMaxSeconds": 30,
    "DeviceSessionSendMinSeconds": 10,
    "DeviceSessionSendMaxSeconds": 30,
    "ClearOutboxOnStartup": true,
    "DeviceSessionCheckpointSeconds": 60,
    "WebSessionFlushSeconds": 15,
    "DeviceHeartbeatEndpoint": "http://localhost:5002/devices/heartbeat",
    "HeartbeatIntervalSeconds": 60
  },
  "LocalApi": {
    "Token": "dev-token-123"
  }
}

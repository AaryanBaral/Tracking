{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Agent.Service.Tracking.AppSessionizer": "Warning",
      "Agent.Service.Workers.OutboxSenderWorker": "Information",
      "Agent.Service.LocalApi.LocalApiHost": "Warning",
      "Startup": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    }
  },
  "Agent": {
    "PollIntervalSeconds": 5,
    "LogIdleEvents": true,
    "LogAppEvents": true,
    "LogWebEvents": true,
    "EnableLocalCollectors": true,
    "ActivitySampleIntervalSeconds": 2,
    "IdleThresholdSeconds": 60,
    "IdleSessionCheckpointSeconds": 0,
    "CompanyEnrollmentKey": "",
    "BrowserEventEndpoint": "https://localhost:5002/events",
    "WebEventIngestEndpoint": "https://localhost:5002/events/web/batch",
    "WebSessionIngestEndpoint": "https://localhost:5002/ingest/web-sessions",
    "AppSessionIngestEndpoint": "https://localhost:5002/ingest/app-sessions",
    "IdleSessionIngestEndpoint": "https://localhost:5002/ingest/idle-sessions",
    "DeviceSessionIngestEndpoint": "https://localhost:5002/ingest/device-sessions",
    "MonitorSessionIngestEndpoint": "https://localhost:5002/ingest/monitor-sessions",
    "ScreenshotIngestEndpoint": "https://localhost:5002/ingest/screenshots",
    "WebEventBatchSize": 50,
    "WebSessionBatchSize": 50,
    "AppSessionBatchSize": 50,
    "IdleSessionBatchSize": 50,
    "DeviceSessionBatchSize": 50,
    "MonitorSessionBatchSize": 50,
    "ScreenshotBatchSize": 20,
    "WebEventSendMinSeconds": 10,
    "WebEventSendMaxSeconds": 30,
    "WebSessionSendMinSeconds": 10,
    "WebSessionSendMaxSeconds": 30,
    "AppSessionSendMinSeconds": 10,
    "AppSessionSendMaxSeconds": 30,
    "IdleSessionSendMinSeconds": 10,
    "IdleSessionSendMaxSeconds": 30,
    "DeviceSessionSendMinSeconds": 10,
    "DeviceSessionSendMaxSeconds": 30,
    "MonitorSessionSendMinSeconds": 10,
    "MonitorSessionSendMaxSeconds": 30,
    "ScreenshotSendMinSeconds": 30,
    "ScreenshotSendMaxSeconds": 120,
    "ClearOutboxOnStartup": false,
    "DeviceSessionCheckpointSeconds": 60,
    "EnableScreenshots": false,
    "ScreenshotIntervalMinutes": 5,
    "ScreenshotRetentionDays": 14,
    "WebSessionFlushSeconds": 15,
    "DeviceHeartbeatEndpoint": "https://localhost:5002/devices/heartbeat",
    "HeartbeatIntervalSeconds": 60
  },
  "LocalApi": {
    "Token": "",
    "AllowedOrigins": [
      "chrome-extension://*"
    ]
  }
}
